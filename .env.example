REDIS_URL=redis://localhost:6379/0

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Leave commented out to use the containerized Ollama service started by docker-compose
# (default: http://ollama:11434 inside the compose network). Uncomment and set to
# http://host.docker.internal:11434 to use your host-installed Ollama instead
# (recommended if 16GB RAM is tight running the full compose stack + a local 8B model).
# Only used directly (as http://localhost:11434) when running app/worker outside docker-compose.
# OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
# Vision model for frame analysis. Requires Ollama >=0.31.1 on the host running it -
# older versions crash on this model with a GGML_ASSERT in the CPU CLIP encoder.
OLLAMA_VISION_MODEL=moondream

VIDEOS_DIR=/data/videos
SEGMENT_WINDOW_SECONDS=8.0

LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=talk-to-your-video
LANGCHAIN_API_KEY=
